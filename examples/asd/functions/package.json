		"ioredis": "^5.6.0",
		"is-svg": "^5.1.0",
		"json-schema-to-ts": "^2.8.0-beta.0",
		"jsonwebtoken": "^9.0.2",
		"lodash": "^4.17.21",
		"mjml": "^4.15.3",
