	"devDependencies": {
		"@types/express": "^5.0.0",
		"@types/lodash": "^4.17.13",
		"express": "4.18.1",
		"json-schema-to-ts": "^2.8.0-beta.0",
		"oas": "^20.10.3",
		"serverless-http": "3.0.2"
	},
	"name": "@trustfolio/backend",
	"private": true,
	"scripts": {
		"down": "export NHOST_PROJECT_NAME=tf-backend && docker compose -f .local/docker-compose.yaml down && nhost down && unset NHOST_PROJECT_NAME",
		"logs:worker": "docker compose -f .local/docker-compose.yaml --ansi=always logs --follow",
		"logs:nhost": "export NHOST_PROJECT_NAME=tf-backend && nhost logs -f",
		"logs": "concurrently -c \"auto\" pnpm:logs:*",
		"dev:flatfile": "pnpm --filter @trustfolio/flatfile run dev",
		"dev:core": "pnpm --filter @trustfolio/core run dev",
		"dev:nhost": "export NHOST_PROJECT_NAME=tf-backend && infisical run -- env-cmd -f ../.env nhost up --http-port 444 --run-service ./gotenberg/nhost-service.toml && docker cp .local/functions/nodemon.json tf-backend-functions-1:/nodemon.json && docker restart tf-backend-functions-1",
		"dev:worker": "docker compose -f .local/docker-compose.yaml up -d --quiet-pull",
		"dev": "pnpm --filter cli command local && nhost sw upgrade && pnpm dev:nhost && pnpm dev:worker",
		"reset": "export NHOST_PROJECT_NAME=tf-backend && nhost down --volumes && unset NHOST_PROJECT_NAME",
		"build": "env-cmd -f ../.env pnpm --filter cli command backend && docker compose -f .local/docker-compose.yaml build",
		"lint": "tsc --noEmit && eslint ./functions --ext .ts --fix",
		"format:prettier": "prettier --write --ignore-path=../.prettierignore .",
		"format": "concurrently pnpm:format:*",
		"clean": "rm -rf .turbo && rm -rf node_modules",
		"nhost:pause": "docker compose -p tf-backend pause",
		"nhost:pgonly": "docker compose -p tf-backend unpause postgres",
		"nhost:unpause": "docker compose -p tf-backend unpause",
		"postinstall": "turbo prune @trustfolio/backend --out-dir .turbo/pruned && cp ../.turbo/pruned/pnpm-lock.yaml ./ && rm -rf ../.turbo/pruned"
	},
	"version": "1.0.0",
	"engines": {
		"node": ">=18.0.0"
	}
}
